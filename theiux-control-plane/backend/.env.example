# --- Database & queue (defaults match docker-compose service names) ---
DATABASE_URL=postgresql+psycopg://theiux:theiux@db:5432/theiux
REDIS_URL=redis://redis:6379/0

# --- Auth ---
JWT_SECRET=change-me
JWT_EXPIRES_MINUTES=15
REFRESH_TOKEN_EXPIRES_DAYS=14
AUTH_RATE_LIMIT_PER_MINUTE=20
AUTH_RATE_LIMIT_BURST=8
AUTH_SECURE_COOKIES=false

# --- Deploy / queue tuning ---
DEPLOY_RETRY_RATE_LIMIT_PER_MINUTE=3
QUEUE_MAX_DEPTH=0
CIRCUIT_WORKER_LAG_SECONDS=0
ENABLE_REFRESH_TOKEN_BINDING=false

# --- Theiux CLI (path inside backend & worker containers) ---
THEIUX_CLI_PATH=/theiux/bin/theiux
THEIUX_DEPLOY_TIMEOUT_SECONDS=3600
THEIUX_INIT_TIMEOUT_SECONDS=3600
ALLOWED_RUNTIME_VERSIONS=node:18,node:20,node:22,python:3.10,python:3.11,go:1.21,go:1.22,ruby:3.2,ruby:3.3

# --- AWS (backend: Terraform UI init; worker: aws ssm via theiux) ---
# With ~/.aws mounted in docker-compose, set the profile from your machine:
AWS_PROFILE=default
# If you do not use ~/.aws, set keys here instead (never commit real secrets):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_SESSION_TOKEN=

# --- Optional: first admin user (set both or neither; password ≥ 12 chars) ---
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me-min-12-chars
