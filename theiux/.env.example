# Project
COMPOSE_PROJECT_NAME=theiux
IMAGE_TAG=latest
FRAPPE_IMAGE_REPO=000000000000.dkr.ecr.us-east-1.amazonaws.com/theiux-frappe
ACTIVE_COLOR=blue
CLOUDWATCH_LOG_GROUP=/theiux/prod/containers

# Build-time parameters (used by CI build args)
PYTHON_VERSION=3.11
NODE_VERSION=20
WKHTMLTOPDF_VERSION=0.12.6.1-3

# Frappe runtime
FRAPPE_GIT_URL=https://github.com/frappe/frappe
FRAPPE_VERSION=version-15
UPDATE_FRAPPE_ON_START=false
APPS_JSON_BASE64=
# For reproducible CI deploys, prefer committed ./apps.json in repo.
# This variable is used as a fallback build input only.
AUTO_CREATE_SITE=true
DEFAULT_SITE=roguesingh.cloud
ADMIN_PASSWORD=change_me_admin_password
APPS_TO_INSTALL=frappe
FRAPPE_PORT=8000
SOCKETIO_PORT=9000
FRAPPE_BACKEND_HOST=frappe
FRAPPE_BACKEND_PORT=8000
FRAPPE_SOCKETIO_HOST=websocket
FRAPPE_SOCKETIO_PORT=9000

# Routing + TLS
SITE_HOSTS=roguesingh.cloud,www.roguesingh.cloud
PRIMARY_DOMAIN=roguesingh.cloud
CERTBOT_EMAIL=singh.sourav2609@gmail.com
CERTBOT_RENEW_INTERVAL_SECONDS=43200
NGINX_TEMPLATE_CHECK_INTERVAL_SECONDS=30
HTTP_PORT=80
HTTPS_PORT=443
CLIENT_MAX_BODY_SIZE=50m
SITE_RATE_LIMIT_RPS=20
SITE_RATE_LIMIT_BURST=40
SITE_CONN_LIMIT=30
SITE_API_RATE_LIMIT_RPS=10
SITE_API_RATE_LIMIT_BURST=20

# Database (set DB_HOST to RDS endpoint for external DB)
DB_HOST=mariadb
DB_PORT=3306
MYSQL_ROOT_PASSWORD=replace_me_root_password
MYSQL_DATABASE=frappe
MYSQL_USER=frappe
MYSQL_PASSWORD=replace_me_db_password

# Redis (set to ElastiCache endpoints for external cache)
REDIS_CACHE=redis://redis-cache:6379/0
REDIS_QUEUE=redis://redis-queue:6379/1
REDIS_SOCKETIO=redis://redis-queue:6379/2
WORKER_PROCESSES=2
WORKER_QUEUES=short,default,long
SITE_REGISTRY_FILE=sites-enabled.csv
ENABLE_DEDICATED_SITE_WORKERS=false
DEDICATED_SITE_WORKERS=
WORKER_SITE_ISOLATION_MODE=shared
TENANT_QUEUE_MODE=shared

# AWS backup/sync
AWS_REGION=us-east-1
S3_BACKUP_BUCKET=theiux-backups
S3_SITE_SYNC_BUCKET=theiux-site-files
ENABLE_S3_SITE_SYNC=false

# Deployment
HEALTHCHECK_URL=https://roguesingh.cloud/api/method/ping
HEALTHCHECK_HOST=roguesingh.cloud
DEPLOY_PATH=/opt/theiux
SSM_PARAMETER_PATH=/theiux/prod
SITE_HEALTH_ENDPOINT=/api/method/ping
SITE_BACKUP_RETENTION_DAYS=14
MAX_DEPLOY_MEMORY_PERCENT=80
TENANT_DB_MAX_USER_CONNECTIONS=15

# One-command provisioning defaults (scripts/provision-and-deploy.sh)
INSTANCE_TYPE=t3.small
ROOT_VOLUME_SIZE_GB=40
SSH_CIDR=0.0.0.0/0
APP_USER=ubuntu
LOCAL_IMAGE_REPO=theiux-frappe
USE_INTERNAL_DB=true
USE_INTERNAL_REDIS=true
# Optional: absolute/relative path to apps.json for multi-app image build
# APPS_JSON_FILE=./apps.json

# Optional automatic EIP + DNS automation (EC2 bootstrap)
RUN_EIP_SETUP=false
AUTO_ALLOCATE_EIP=true
EIP_ALLOCATION_ID=
# Create a public hosted zone in Route53, then set its ID here (see scripts/route53-sync-dns.sh).
HOSTED_ZONE_ID=
DOMAIN_NAME=roguesingh.cloud
CREATE_WWW_RECORD=true
# When true (default), provision-and-deploy.sh and successful deploy.sh runs upsert apex (+www) A records.
AUTO_ROUTE53_DNS=true
